{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["collections"],
  "additionalProperties": false,
  "properties": {
    "collections": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["disposition"],
        "properties": {
          "anchorTable": { "type": "string" },
          "disposition": {
            "enum": ["anchor", "separate_collection", "embedded"]
          },
          "productionDocumentCount": { "type": "integer", "minimum": 0 },
          "embeddedInCollection": { "type": "string" }
        }
      }
    },
    "embedded": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "embeddedInCollection": { "type": "string" },
          "parentTable": { "type": "string" },
          "avgCardinality": { "type": "number", "minimum": 0 },
          "ratioLabel": { "type": "string" },
          "derivedFrom": { "type": "object" }
        }
      }
    },
    "databaseProductionDocumentCount": { "type": "integer", "minimum": 0 }
  }
}
